{
  "name": "shakespii",
  "version": "0.3.2",
  "description": "Workbench for AI agent skills — init, lint, test, bench, and gate-checked install of standard SKILL.md skills",
  "license": "MIT",
  "type": "module",
  "bin": {
    "shakespii": "src/cli/index.ts"
  },
  "files": [
    "src",
    "templates",
    "profiles",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuphanse/ai-shakespii.git"
  },
  "bugs": {
    "url": "https://github.com/vuphanse/ai-shakespii/issues"
  },
  "homepage": "https://github.com/vuphanse/ai-shakespii#readme",
  "keywords": [
    "agent-skills",
    "skills",
    "skill",
    "claude",
    "codex",
    "lint",
    "eval",
    "cli",
    "ai-agents"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check-pack": "bun scripts/check-pack.ts"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
